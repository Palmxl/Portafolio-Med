---
const navLinks = [
  { label: "Sobre mí", href: "#about" },
  { label: "Servicios", href: "#services" },
  { label: "Citas", href: "#appointment" },
  { label: "Contacto", href: "#contact" },
];
---

<header class="navbar">
  <div class="navbar__brand">
    <img src="/images/logo2.png" alt="Nathalia Sánchez" class="navbar__logo-img" />
  </div>

  <nav class="navbar__nav">
    {navLinks.map((link) => (
      <a href={link.href} class="navbar__link">{link.label}</a>
    ))}
  </nav>

  <a href="https://wa.me/573026399527" target="_blank" class="navbar__cta">
    Agendar Cita
  </a>
</header>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 18rem 0 28rem;
    background: transparent;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .navbar__logo-img {
    height: 115px;        /* ← antes 95px */
    width: auto;
    object-fit: contain;
  }

  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 3rem;            /* ← antes 2.5rem */
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .navbar__link {
    font-family: 'Georgia', serif;
    font-size: 1.05rem;   /* ← antes 0.9rem */
    color: #2c4a5a;
    text-decoration: none;
    letter-spacing: 0.01em;
    position: relative;
    padding-bottom: 4px;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: #1a6faa;
    transition: width 0.3s ease;
  }

  .navbar__link:hover::after {
    width: 100%;
  }

  .navbar__link:hover {
    color: #2c4a5a;
  }

  .navbar__cta {
    background: #1a6faa;
    color: white;
    border: none;
    border-radius: 25px;
    padding: 0.85rem 1.8rem;   
    font-family: 'Georgia', serif;
    font-size: 1rem;           
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
    letter-spacing: 0.01em;
    margin-right: 5rem;
    text-decoration: none;
  }

  .navbar__cta:hover {
    background: #3a9aaa;
    transform: translateY(-1px);
  }

  .navbar--scrolled {
    background: white;
    box-shadow: 0 2px 20px rgba(0,0,0,0.06);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
</style>

<script is:inline>
  window.addEventListener('scroll', () => {
    const navbar = document.querySelector('.navbar');
    if (window.scrollY > 20) {
      navbar.classList.add('navbar--scrolled');
    } else {
      navbar.classList.remove('navbar--scrolled');
    }
  });
</script>