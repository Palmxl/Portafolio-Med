---
const navLinks = [
  { label: "About", href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Appointment", href: "#appointment" },
  { label: "Contact", href: "#contact" },
];
---

<header class="navbar">
  <div class="navbar__brand">
    <div class="navbar__logo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L13.5 8.5H20L14.5 12.5L16.5 19L12 15L7.5 19L9.5 12.5L4 8.5H10.5L12 2Z" fill="#4AADBC"/>
        <rect x="10" y="6" width="4" height="12" rx="1" fill="#4AADBC"/>
        <rect x="6" y="10" width="12" height="4" rx="1" fill="#4AADBC"/>
      </svg>
    </div>
    <div class="navbar__brand-info">
      <span class="navbar__brand-name">MedPortfolio</span>
      <span class="navbar__badge">
        <span class="navbar__badge-dot"></span>
        MD · BOARD CERTIFIED · 15+ YEARS
      </span>
    </div>
  </div>

  <nav class="navbar__nav">
    {navLinks.map((link) => (
      <a href={link.href} class="navbar__link">{link.label}</a>
    ))}
  </nav>

  <button class="navbar__cta">Book Appointment</button>
</header>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 2.5rem;
    background: transparent;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .navbar__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .navbar__logo {
    background: #e8f4f7;
    border-radius: 8px;
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .navbar__brand-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .navbar__brand-name {
    font-family: 'Georgia', serif;
    font-size: 1rem;
    font-weight: 600;
    color: #1a2f3a;
    line-height: 1;
  }

  .navbar__badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: white;
    border: 1px solid #d0e8ef;
    border-radius: 20px;
    padding: 3px 10px;
    font-size: 0.6rem;
    font-family: 'Georgia', serif;
    letter-spacing: 0.08em;
    color: #4a7a8a;
    font-weight: 500;
    width: fit-content;
  }

  .navbar__badge-dot {
    width: 6px;
    height: 6px;
    background: #4AADBC;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .navbar__link {
    font-family: 'Georgia', serif;
    font-size: 0.9rem;
    color: #2c4a5a;
    text-decoration: none;
    transition: color 0.2s ease;
    letter-spacing: 0.01em;
  }

  .navbar__link:hover {
    color: #4AADBC;
  }

  .navbar__cta {
    background: #4AADBC;
    color: white;
    border: none;
    border-radius: 25px;
    padding: 0.65rem 1.4rem;
    font-family: 'Georgia', serif;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
    letter-spacing: 0.01em;
  }

  .navbar__cta:hover {
    background: #3a9aaa;
    transform: translateY(-1px);
  }
</style>