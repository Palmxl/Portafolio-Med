---
const services = [
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    tag: "MÁS POPULAR",
    title: "Consulta de Otorrinolaringología",
    description: "Consulta especializada para niños y adultos. Evaluación del oído, nariz, garganta y estructuras del cuello y cabeza.",
    featured: true,
    cta: true,
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>`,
    title: "Nasolaringoscopia",
    description: "Evaluación endoscópica de cavidad nasal, faringe y laringe para enfermedades que afectan la voz, respiración y deglución.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: "Estroboscopia Laríngea",
    description: "Evaluación altamente especializada de las cuerdas vocales. Estudio de elección para profesionales de la voz.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: "Evaluación de Deglución",
    description: "Evaluación endoscópica para alteraciones en la deglución de alimentos y líquidos en pacientes con disfagia.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: "Procedimientos Ambulatorios",
    description: "Control de epistaxis, extracción de cuerpos extraños, limpieza de oído y otros procedimientos bajo visión endoscópica.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Cirugía de Laringología",
    description: "Cirugía de voz, pólipos, nódulos, estenosis laringotraqueales, septoplastia, amigdalectomía y más procedimientos quirúrgicos.",
  },
];
---

<section class="services" id="services">
  <div class="services__container">

    <div class="services__header services__animate services__animate--1">
      <div class="services__header-left">
        <p class="services__label">
          <span class="services__label-line"></span>
          LO QUE OFREZCO
        </p>
        <h2 class="services__title">
          Atención integral<br />
          <em class="services__title-em">en cada etapa de tu vida</em>
        </h2>
      </div>
      <p class="services__subtitle">
        Desde consultas de rutina hasta procedimientos especializados — medicina basada en evidencia con atención genuina.
      </p>
    </div>

    <div class="services__grid services__animate services__animate--2">

      <div class="services__card services__card--featured">
        <div class="services__card-icon" set:html={services[0].icon}></div>
        <span class="services__card-tag">{services[0].tag}</span>
        <h3 class="services__card-title">{services[0].title}</h3>
        <p class="services__card-desc">{services[0].description}</p>
        <button class="services__card-btn">Agendar Cita</button>
      </div>

      <div class="services__card services__card--tall">
        <div class="services__card-icon" set:html={services[1].icon}></div>
        <h3 class="services__card-title">{services[1].title}</h3>
        <p class="services__card-desc">{services[1].description}</p>
        <div class="services__card-line"></div>
      </div>

      <div class="services__subgrid">
        <div class="services__card">
          <div class="services__card-icon" set:html={services[2].icon}></div>
          <h3 class="services__card-title">{services[2].title}</h3>
          <p class="services__card-desc">{services[2].description}</p>
          <div class="services__card-line"></div>
        </div>
        <div class="services__card">
          <div class="services__card-icon" set:html={services[3].icon}></div>
          <h3 class="services__card-title">{services[3].title}</h3>
          <p class="services__card-desc">{services[3].description}</p>
          <div class="services__card-line"></div>
        </div>
      </div>

      <div class="services__card services__card--row3-left">
        <div class="services__card-icon" set:html={services[4].icon}></div>
        <h3 class="services__card-title">{services[4].title}</h3>
        <p class="services__card-desc">{services[4].description}</p>
        <div class="services__card-line"></div>
      </div>

      <div class="services__card services__card--row3-right">
        <div class="services__card-icon" set:html={services[5].icon}></div>
        <h3 class="services__card-title">{services[5].title}</h3>
        <p class="services__card-desc">{services[5].description}</p>
        <div class="services__card-line"></div>
      </div>

    </div>

    <p class="services__footer services__animate services__animate--3">
      ¿No sabes qué servicio necesitas?{" "}
      <a href="#appointment" class="services__footer-link">Agenda una consulta</a>
      {" "}y te orientamos.
    </p>

  </div>
</section>

<style>
  .services {
    background: #eaf4f8;
    padding: 8rem 2.5rem;
    border-top: 1px solid rgba(212, 175, 55, 0.4);
  }

  .services__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .services__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 3rem;
  }

  .services__header-left {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .services__label {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-family: 'Georgia', serif;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: #c07a50;
    font-weight: 600;
    margin: 0;
  }

  .services__label-line {
    display: inline-block;
    width: 28px;
    height: 1.5px;
    background: #c07a50;
  }

  .services__title {
    font-family: 'Georgia', serif;
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 700;
    color: #1a2f3a;
    line-height: 1.15;
    margin: 0;
  }

  .services__title-em {
    font-style: italic;
    font-weight: 400;
    color: #1a6faa;
  }

  .services__subtitle {
    font-family: 'Georgia', serif;
    font-size: 1rem;
    color: #4a6070;
    line-height: 1.7;
    max-width: 300px;
    text-align: right;
    margin: 0;
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    grid-template-rows: auto auto auto;
    gap: 1.2rem;
  }

  .services__card--featured {
    grid-column: 1;
    grid-row: 1;
  }

  .services__card--tall {
    grid-column: 2;
    grid-row: 1 / 3;
  }

  .services__subgrid {
    grid-column: 1;
    grid-row: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .services__card--row3-left {
    grid-column: 1;
    grid-row: 3;
  }

  .services__card--row3-right {
    grid-column: 2;
    grid-row: 3;
  }

  .services__card {
    background: white;
    border-radius: 16px;
    padding: 2.2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 1px solid #e0ecf2;
    transition: box-shadow 0.2s ease;
  }

  .services__card:hover {
    box-shadow: 0 8px 30px rgba(26,111,170,0.1);
  }

  .services__card--featured {
    background: #1a6faa;
    border-color: transparent;
    padding: 2.8rem;
  }

  .services__card--featured .services__card-title,
  .services__card--featured .services__card-desc {
    color: white;
  }

  .services__card-icon {
    width: 44px;
    height: 44px;
    background: rgba(26,111,170,0.1);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a6faa;
  }

  .services__card--featured .services__card-icon {
    background: rgba(255,255,255,0.2);
    color: white;
  }

  .services__card-tag {
    font-family: 'Georgia', serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.15);
    border-radius: 20px;
    padding: 4px 12px;
    width: fit-content;
  }

  .services__card-title {
    font-family: 'Georgia', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: #1a2f3a;
    margin: 0;
    line-height: 1.3;
  }

  .services__card-desc {
    font-family: 'Georgia', serif;
    font-size: 0.92rem;
    color: #4a6070;
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  .services__card-btn {
    background: white;
    color: #1a6faa;
    border: none;
    border-radius: 20px;
    padding: 0.7rem 1.6rem;
    font-family: 'Georgia', serif;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    width: fit-content;
    margin-top: 0.5rem;
    transition: all 0.2s ease;
  }

  .services__card-btn:hover {
    background: #1a2f3a;
    color: white;
  }

  .services__card-line {
    width: 40px;
    height: 2px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(212, 175, 55, 0.6) 50%,
      transparent 100%
    );
    margin-top: 0.3rem;
  }

  .services__footer {
    text-align: center;
    font-family: 'Georgia', serif;
    font-size: 0.95rem;
    color: #4a6070;
    margin: 0;
  }

  .services__footer-link {
    color: #1a6faa;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Animaciones ── */
  .services__animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .services__animate--1 { transition-delay: 0.1s; }
  .services__animate--2 { transition-delay: 0.25s; }
  .services__animate--3 { transition-delay: 0.4s; }

  .services__animate.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  const observerServices = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observerServices.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0,
    rootMargin: '0px 0px -50px 0px'
  });

  document.querySelectorAll('.services__animate').forEach(el => observerServices.observe(el));
</script>