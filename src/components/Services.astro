---
const services = [
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    tag: "MOST POPULAR",
    title: "Preventive Care",
    description: "Annual physicals, health screenings, immunizations, and personalized wellness plans designed to keep you healthy before issues arise.",
    featured: true,
    cta: true,
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>`,
    title: "Chronic Disease Management",
    description: "Ongoing care for diabetes, hypertension, thyroid disorders, and other long-term conditions with regular monitoring and medication management.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    title: "Diagnostic Evaluation",
    description: "Thorough assessment of new symptoms, comprehensive lab work interpretation, and specialist referrals when needed.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: "Health Risk Assessment",
    description: "Detailed evaluation of genetic, lifestyle, and environmental risk factors to build a proactive health strategy.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: "Acute Care Visits",
    description: "Same-day or next-day appointments for sudden illness, infections, injuries, and urgent non-emergency concerns.",
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Telehealth Consultations",
    description: "Secure video visits for follow-ups, prescription renewals, and consultations from the comfort of your home.",
  },
];
---

<section class="services" id="services">
  <div class="services__container">

    <div class="services__header">
      <div class="services__header-left">
        <p class="services__label">
          <span class="services__label-line"></span>
          WHAT I OFFER
        </p>
        <h2 class="services__title">
          Comprehensive care<br />
          <em class="services__title-em">for every stage of life</em>
        </h2>
      </div>
      <p class="services__subtitle">
        From routine checkups to complex condition management — evidence-based medicine delivered with genuine care.
      </p>
    </div>

    <div class="services__grid">

      <!-- Col izquierda fila 1: Featured -->
      <div class="services__card services__card--featured">
        <div class="services__card-icon" set:html={services[0].icon}></div>
        <span class="services__card-tag">{services[0].tag}</span>
        <h3 class="services__card-title">{services[0].title}</h3>
        <p class="services__card-desc">{services[0].description}</p>
        <button class="services__card-btn">Book Now</button>
      </div>

      <!-- Col derecha fila 1+2: Chronic Disease -->
      <div class="services__card services__card--tall">
        <div class="services__card-icon" set:html={services[1].icon}></div>
        <h3 class="services__card-title">{services[1].title}</h3>
        <p class="services__card-desc">{services[1].description}</p>
        <div class="services__card-line"></div>
      </div>

      <!-- Col izquierda fila 2: subgrid con 2 cards -->
      <div class="services__subgrid">
        <div class="services__card">
          <div class="services__card-icon" set:html={services[2].icon}></div>
          <h3 class="services__card-title">{services[2].title}</h3>
          <p class="services__card-desc">{services[2].description}</p>
          <div class="services__card-line"></div>
        </div>
        <div class="services__card">
          <div class="services__card-icon" set:html={services[3].icon}></div>
          <h3 class="services__card-title">{services[3].title}</h3>
          <p class="services__card-desc">{services[3].description}</p>
          <div class="services__card-line"></div>
        </div>
      </div>

      <!-- Col izquierda fila 3: Acute Care -->
      <div class="services__card services__card--row3-left">
        <div class="services__card-icon" set:html={services[4].icon}></div>
        <h3 class="services__card-title">{services[4].title}</h3>
        <p class="services__card-desc">{services[4].description}</p>
        <div class="services__card-line"></div>
      </div>

      <!-- Col derecha fila 3: Telehealth -->
      <div class="services__card services__card--row3-right">
        <div class="services__card-icon" set:html={services[5].icon}></div>
        <h3 class="services__card-title">{services[5].title}</h3>
        <p class="services__card-desc">{services[5].description}</p>
        <div class="services__card-line"></div>
      </div>

    </div>

    <p class="services__footer">
      Not sure which service fits your needs?{" "}
      <a href="#appointment" class="services__footer-link">Book a consultation</a>
      {" "}and we will guide you.
    </p>

  </div>
</section>

<style>
  .services {
    background: #eaf4f8;
    padding: 7rem 2.5rem;
  }

  .services__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .services__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 3rem;
  }

  .services__header-left {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .services__label {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-family: 'Georgia', serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: #c07a50;
    font-weight: 600;
    margin: 0;
  }

  .services__label-line {
    display: inline-block;
    width: 28px;
    height: 1.5px;
    background: #c07a50;
  }

  .services__title {
    font-family: 'Georgia', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    color: #1a2f3a;
    line-height: 1.15;
    margin: 0;
  }

  .services__title-em {
    font-style: italic;
    font-weight: 400;
    color: #4AADBC;
  }

  .services__subtitle {
    font-family: 'Georgia', serif;
    font-size: 0.9rem;
    color: #4a6070;
    line-height: 1.7;
    max-width: 280px;
    text-align: right;
    margin: 0;
  }

  /* ── Grid principal ── */
  .services__grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    grid-template-rows: auto auto auto;
    gap: 1.2rem;
  }

  .services__card--featured {
    grid-column: 1;
    grid-row: 1;
  }

  .services__card--tall {
    grid-column: 2;
    grid-row: 1 / 3;
  }

  .services__subgrid {
    grid-column: 1;
    grid-row: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .services__card--row3-left {
    grid-column: 1;
    grid-row: 3;
  }

  .services__card--row3-right {
    grid-column: 2;
    grid-row: 3;
  }

  /* ── Cards ── */
  .services__card {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    border: 1px solid #e0ecf2;
    transition: box-shadow 0.2s ease;
  }

  .services__card:hover {
    box-shadow: 0 8px 30px rgba(74,173,188,0.1);
  }

  .services__card--featured {
    background: #5a9faf;
    border-color: transparent;
    padding: 2.5rem;
  }

  .services__card--featured .services__card-title,
  .services__card--featured .services__card-desc {
    color: white;
  }

  .services__card-icon {
    width: 40px;
    height: 40px;
    background: rgba(74,173,188,0.12);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4AADBC;
  }

  .services__card--featured .services__card-icon {
    background: rgba(255,255,255,0.2);
    color: white;
  }

  .services__card-tag {
    font-family: 'Georgia', serif;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.15);
    border-radius: 20px;
    padding: 3px 10px;
    width: fit-content;
  }

  .services__card-title {
    font-family: 'Georgia', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a2f3a;
    margin: 0;
    line-height: 1.3;
  }

  .services__card-desc {
    font-family: 'Georgia', serif;
    font-size: 0.85rem;
    color: #4a6070;
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  .services__card-btn {
    background: white;
    color: #2c4a5a;
    border: none;
    border-radius: 20px;
    padding: 0.6rem 1.4rem;
    font-family: 'Georgia', serif;
    font-size: 0.82rem;
    cursor: pointer;
    width: fit-content;
    margin-top: 0.5rem;
    transition: all 0.2s ease;
  }

  .services__card-btn:hover {
    background: #1a2f3a;
    color: white;
  }

  .services__card-line {
    width: 24px;
    height: 2px;
    background: #d0e8f0;
    margin-top: 0.3rem;
  }

  .services__footer {
    text-align: center;
    font-family: 'Georgia', serif;
    font-size: 0.88rem;
    color: #4a6070;
    margin: 0;
  }

  .services__footer-link {
    color: #4AADBC;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>