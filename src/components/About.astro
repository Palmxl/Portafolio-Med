---
const stats = [
  { value: "2+", label: "ESPECIALIDADES" },
  { value: "100%", label: "COMPROMISO" },
  { value: "98%", label: "SATISFACCIÓN" },
  { value: "12+", label: "RECONOCIMIENTOS" },
];

const credentials = [
  { type: "Médica y Cirujana", institution: "Universidad Militar Nueva Granada", year: "2015" },
  { type: "ORL", institution: "Especialista en Otorrinolaringología", year: "2019" },
  { type: "Laringología", institution: "Subespecialidad Vía Aérea Superior", year: "2021" },
  { type: "Certificada", institution: "Asociación Colombiana de ORL", year: "2021" },
];
---

<section class="about" id="about">
  <div class="about__container">
    <div class="about__left about__animate about__animate--left">
      <p class="about__label">
        <span class="about__label-line"></span>
        SOBRE LA DOCTORA
      </p>
      <div class="about__img-wrapper">
        <div class="about__corner about__corner--tl"></div>
        <div class="about__corner about__corner--br"></div>
        <img src="/Portafolio-Med/images/ABOUT.JPG" alt="Dra. Nathalia Sánchez" class="about__img" />
        <div class="about__badge">
          <span class="about__badge-dot"></span>
          <div>
            <p class="about__badge-title">CERTIFICADA</p>
            <p class="about__badge-sub">Asociación Colombiana de ORL</p>
          </div>
        </div>
      </div>
    </div>

    <div class="about__right">
      <h2 class="about__title about__animate about__animate--1">
        Dedicada a tu<br />
        <em class="about__title-em">bienestar a largo plazo</em>
      </h2>

      <div class="about__divider about__animate about__animate--2"></div>

      <p class="about__text about__animate about__animate--3">
        Médica y cirujana especialista en otorrinolaringología con segunda especialidad en 
        laringología y vía aérea superior, de la Universidad Militar Nueva Granada. 
        Con gran compromiso en el ejercicio de su profesión y en la educación médica 
        continuada para brindar a sus pacientes una atención integral y con alto sentido humano.
      </p>

      <p class="about__text about__animate about__animate--4">
        Líder en el área de enfermedades que afectan la voz, deglución y respiración. 
        Actualmente miembro de la Asociación Colombiana de Otorrinolaringología y Cirugía 
        de cabeza y cuello, docente adjunta y especialista del Hospital Universitario San Ignacio.
      </p>

      <div class="about__stats about__animate about__animate--5">
        {stats.map((stat) => (
          <div class="about__stat">
            <span class="about__stat-value">{stat.value}</span>
            <span class="about__stat-label">{stat.label}</span>
          </div>
        ))}
      </div>

      <div class="about__credentials about__animate about__animate--6">
        <p class="about__cred-title">EDUCACIÓN Y CREDENCIALES</p>
        {credentials.map((cred) => (
          <div class="about__cred-row">
            <span class="about__cred-type">{cred.type}</span>
            <span class="about__cred-institution">{cred.institution}</span>
            <span class="about__cred-year">{cred.year}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: #fff;
    padding: 7rem 2.5rem;
    position: relative;
    overflow: visible;
    border-top: 1px solid rgba(212, 175, 55, 0.4);
  }

  .about__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    gap: 5rem;
    align-items: flex-start;
    min-height: 900px;
  }

  .about__left {
    position: sticky;
    top: 96px;
    flex: 0 0 42%;
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .about__img-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: visible;
    border: 1px solid #e8f0f4;
  }

  .about__img {
    width: 100%;
    height: auto;
    object-fit: unset;
    display: block;
    border-radius: 16px;
  }

  .about__corner {
    position: absolute;
    width: 55px;
    height: 55px;
    z-index: 2;
  }

  .about__corner--tl {
    top: -14px;
    left: -14px;
    border-top: 3px solid #c07a50;
    border-left: 3px solid #c07a50;
    border-radius: 4px 0 0 0;
  }

  .about__corner--br {
    bottom: -14px;
    right: -14px;
    border-bottom: 3px solid #c07a50;
    border-right: 3px solid #c07a50;
    border-radius: 0 0 4px 0;
  }

  .about__badge {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    background: white;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

  .about__badge-dot {
    width: 8px;
    height: 8px;
    background: #1a6faa;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .about__badge-title {
    font-family: 'Georgia', serif;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: #1a6faa;
    font-weight: 600;
    margin: 0;
  }

  .about__badge-sub {
    font-family: 'Georgia', serif;
    font-size: 0.75rem;
    color: #2c4a5a;
    margin: 0;
  }

  .about__right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
    padding-top: 5rem;
  }

  .about__label {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-family: 'Georgia', serif;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: #c07a50;
    font-weight: 600;
    margin: 0;
  }

  .about__label-line {
    display: inline-block;
    width: 28px;
    height: 1.5px;
    background: #c07a50;
  }

  .about__title {
    font-family: 'Georgia', serif;
    font-size: clamp(2.8rem, 3.2vw, 4rem);
    font-weight: 700;
    color: #1a2f3a;
    line-height: 1.2;
    margin: 0;
  }

  .about__title-em {
    font-style: italic;
    font-weight: 400;
    color: #1a6faa;
  }

  .about__divider {
    width: 590px;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(212, 175, 55, 0.6) 50%,
      transparent 100%
    );
    align-self: center;
  }

  .about__text {
    font-family: 'Georgia', serif;
    font-size: 1rem;
    color: #4a6070;
    line-height: 1.8;
    margin: 0;
  }

  .about__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .about__stat {
    background: #f4f9fb;
    border-radius: 12px;
    padding: 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .about__stat-value {
    font-family: 'Georgia', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #1a2f3a;
    line-height: 1;
  }

  .about__stat-label {
    font-family: 'Georgia', serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: #7a9aaa;
    font-weight: 500;
  }

  .about__credentials {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }

  .about__cred-title {
    font-family: 'Georgia', serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: #7a9aaa;
    font-weight: 600;
    margin: 0 0 0.4rem;
  }

  .about__cred-row {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    align-items: center;
    padding: 0.7rem 0;
    border-bottom: 1px solid #f0f4f6;
  }

  .about__cred-type {
    font-family: 'Georgia', serif;
    font-size: 0.85rem;
    color: #1a6faa;
    font-weight: 600;
  }

  .about__cred-institution {
    font-family: 'Georgia', serif;
    font-size: 0.9rem;
    color: #2c4a5a;
  }

  .about__cred-year {
    font-family: 'Georgia', serif;
    font-size: 0.85rem;
    color: #9ab0bb;
  }

  /* ── Animaciones ── */
  .about__animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .about__animate--left {
    transform: translateX(-30px);
  }

  .about__animate--1 { transition-delay: 0.1s; }
  .about__animate--2 { transition-delay: 0.2s; }
  .about__animate--3 { transition-delay: 0.3s; }
  .about__animate--4 { transition-delay: 0.4s; }
  .about__animate--5 { transition-delay: 0.5s; }
  .about__animate--6 { transition-delay: 0.6s; }

  .about__animate.visible {
    opacity: 1;
    transform: translateY(0) translateX(0);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .about__container {
      gap: 3rem;
      min-height: unset;
    }

    .about__left {
      flex: 0 0 45%;
      gap: 3rem;
    }

    .about__right {
      padding-top: 3rem;
    }

    .about__divider {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .about {
      padding: 5rem 1.8rem;
    }

    .about__container {
      flex-direction: column;
      gap: 3rem;
      min-height: unset;
    }

    .about__left {
      position: relative;
      top: unset;
      flex: unset;
      width: 100%;
      gap: 2rem;
    }

    .about__img {
      max-height: 500px;
      object-fit: cover;
      object-position: top center;
    }

    .about__right {
      padding-top: 0;
      gap: 1.4rem;
    }

    .about__title {
      font-size: clamp(2rem, 6vw, 2.8rem);
    }

    .about__divider {
      width: 100%;
    }

    .about__cred-row {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }

    .about__cred-year {
      font-size: 0.75rem;
    }

    .about__corner {
      width: 35px;
      height: 35px;
    }
  }

  @media (max-width: 480px) {
    .about {
      padding: 4rem 1.2rem;
    }

    .about__stats {
      grid-template-columns: 1fr 1fr;
      gap: 0.8rem;
    }

    .about__stat {
      padding: 1rem 1.2rem;
    }

    .about__stat-value {
      font-size: 1.6rem;
    }

    .about__badge {
      bottom: 1rem;
      right: 1rem;
      padding: 0.5rem 0.8rem;
    }

    .about__badge-sub {
      font-size: 0.65rem;
    }
  }
</style>

<script is:inline>
  const observerAbout = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observerAbout.unobserve(entry.target);
      }
    });
  }, { 
    threshold: 0,
    rootMargin: '0px 0px -50px 0px'
  });

  document.querySelectorAll('.about__animate').forEach(el => observerAbout.observe(el));
</script>