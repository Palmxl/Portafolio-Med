<style>
  .footer {
    background: #fff;
    padding: 1.2rem 2.5rem;
    border-top: 1px solid rgba(212, 175, 55, 0.4);
  }

  .footer__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer__brand-name {
    font-family: 'Georgia', serif;
    font-size: 0.85rem;
    color: #9ab0bb;
    margin: 0;
  }

  .footer__nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .footer__link {
    font-family: 'Georgia', serif;
    font-size: 0.95rem;
    color: #4a6070;
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 3px;
  }

  .footer__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 1.5px;
    background: #1a6faa;
    transition: width 0.3s ease;
  }

  .footer__link:hover::after {
    width: 100%;
  }

  .footer__link:hover {
    color: #4a6070;
  }

  .footer__social {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .footer__social-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #f0f8fa;
    color: #1a6faa;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid #d0e8f0;
  }

  .footer__social-btn:hover {
    background: #1a6faa;
    color: white;
    border-color: #1a6faa;
    transform: translateY(-2px);
  }

  .footer__social-btn--wa {
    color: #25D366;
    border-color: #c8efd8;
    background: #f0fdf4;
  }

  .footer__social-btn--wa:hover {
    background: #25D366;
    color: white;
    border-color: #25D366;
  }

  .footer__social-btn svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* ── Animaciones ── */
  .footer__animate {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .footer__animate--1 { transition-delay: 0.1s; }
  .footer__animate--2 { transition-delay: 0.2s; }
  .footer__animate--3 { transition-delay: 0.3s; }

  .footer__animate.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  const observerFooter = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observerFooter.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0,
    rootMargin: '0px 0px -20px 0px'
  });

  document.querySelectorAll('.footer__animate').forEach(el => observerFooter.observe(el));
</script>