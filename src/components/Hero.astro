---
const stats = [
  { value: "ORL", label: "ESPECIALISTA" },
  { value: "2+", label: "ESPECIALIDADES" },
  { value: "100%", label: "COMPROMISO" },
];
---

<section class="hero">
  <div class="hero__bg">
    <img
      src="/Portafolio-Med/images/HERO.JPG"
      alt="Dra. Nathalia Sanchez"
      class="hero__bg-img"
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    <div class="hero__text">
      <h1 class="hero__name hero__animate hero__animate--1">
        <span class="hero__name-first">Dra. Nathalia</span>
        <span class="hero__name-last">Sánchez</span>
      </h1>

      <p class="hero__specialty hero__animate hero__animate--2">
        <span class="hero__specialty-line"></span>
        OTORRINOLARINGOLOGÍA · VOZ Y DEGLUCIÓN
      </p>

      <p class="hero__description hero__animate hero__animate--3">
        Especialista en otorrinolaringología con subespecialidad en laringología y vía aérea superior. 
        Atención integral, humanizada y basada en evidencia para niños y adultos.
      </p>

      <div class="hero__actions hero__animate hero__animate--4">
        <button class="hero__btn hero__btn--primary">Agendar Cita</button>
        <a href="/cv.pdf" target="_blank" class="hero__btn hero__btn--secondary">
          Ver CV
        </a>
      </div>
    </div>

    <div class="hero__stats hero__animate hero__animate--5">
      {stats.map((stat) => (
        <div class="hero__stat">
          <span class="hero__stat-value">{stat.value}</span>
          <span class="hero__stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="hero__scroll">
    <span class="hero__scroll-text">SCROLL</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: #eaf4f8;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero__bg-img {
    position: absolute;
    right: 0;
    top: 55%;
    transform: translateY(-50%);
    width: auto;
    height: 110%;
    object-fit: unset;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    background: linear-gradient(
      to right,
      #eaf4f8 0%,
      #eaf4f8 60%,
      rgba(234,244,248,0.95) 65%,
      rgba(234,244,248,0.7) 70%,
      rgba(234,244,248,0.2) 78%,
      transparent 85%
    );
  }

  .hero__bg-overlay {
    display: none;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    padding: 8.5rem 2.5rem 3rem 28rem;
    max-width: 980px;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .hero__name {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
    margin: 0;
  }

  .hero__name-first {
    font-family: 'Georgia', serif;
    font-size: clamp(3.4rem, 6vw, 5.2rem);
    font-weight: 700;
    color: #1a2f3a;
    letter-spacing: -0.02em;
  }

  .hero__name-last {
    font-family: 'Georgia', serif;
    font-size: clamp(3.4rem, 6vw, 5.2rem);
    font-weight: 400;
    color: #1a6faa;
    letter-spacing: -0.02em;
  }

  .hero__specialty {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-family: 'Georgia', serif;
    font-size: 0.9rem;
    letter-spacing: 0.12em;
    color: #c07a50;
    font-weight: 600;
    margin: 0;
  }

  .hero__specialty-line {
    display: inline-block;
    width: 30px;
    height: 1.5px;
    background: #c07a50;
    flex-shrink: 0;
  }

  .hero__description {
    font-family: 'Georgia', serif;
    font-size: 1.1rem;
    color: #4a6070;
    line-height: 1.7;
    max-width: 500px;
    margin: 0;
  }

  .hero__actions {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  .hero__btn {
    border-radius: 30px;
    padding: 1rem 2.2rem;
    font-family: 'Georgia', serif;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
  }

  .hero__btn--primary {
    background: #1a6faa;
    color: white;
  }

  .hero__btn--primary:hover {
    background: #155d8f;
    transform: translateY(-2px);
  }

  .hero__btn--secondary {
    background: white;
    color: #2c4a5a;
    border: 1.5px solid #d0e0e8;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .hero__btn--secondary:hover {
    border-color: #1a6faa;
    color: #1a6faa;
    transform: translateY(-2px);
  }

  .hero__stats {
    display: flex;
    gap: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid #cde0e8;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .hero__stat-value {
    font-family: 'Georgia', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #1a2f3a;
    line-height: 1;
  }

  .hero__stat-label {
    font-family: 'Georgia', serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: #7a9aaa;
    font-weight: 500;
  }

  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
  }

  .hero__scroll-text {
    font-family: 'Georgia', serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: #7a9aaa;
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, #4AADBC, transparent);
    animation: scrollPulse 1.8s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* ── Animaciones ── */
  .hero__animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .hero__animate--1 { transition-delay: 0.1s; }
  .hero__animate--2 { transition-delay: 0.25s; }
  .hero__animate--3 { transition-delay: 0.4s; }
  .hero__animate--4 { transition-delay: 0.55s; }
  .hero__animate--5 { transition-delay: 0.7s; }

  .hero__animate.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.hero__animate').forEach(el => observer.observe(el));
</script>